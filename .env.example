# Turso Cloud Database Credentials (Mumbai region recommended for Indian users)
TURSO_DATABASE_URL="libsql://your-database-name-username.turso.io"
TURSO_AUTH_TOKEN="your_copied_auth_token_here"

# Secure random session secret (used for auth cookies/sessions)
SESSION_SECRET="change-me-to-some-very-long-secret-key-12345"
